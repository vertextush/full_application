# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=myapp_db

# ==========================================
# MICROSERVICES - Database Connection
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=myapp_db

# ==========================================
# MICROSERVICES - Ports
# ==========================================
USER_SERVICE_PORT=3001
DASHBOARD_SERVICE_PORT=3002
SETTINGS_SERVICE_PORT=3003

# ==========================================
# FRONTEND - Service Discovery
# ==========================================
# For Docker Compose (default)
USER_SERVICE_URL=http://user-service:3001
DASHBOARD_SERVICE_URL=http://dashboard-service:3002
SETTINGS_SERVICE_URL=http://settings-service:3003

# For Kubernetes, uncomment and update:
# USER_SERVICE_URL=http://user-service.default.svc.cluster.local:3001
# DASHBOARD_SERVICE_URL=http://dashboard-service.default.svc.cluster.local:3002
# SETTINGS_SERVICE_URL=http://settings-service.default.svc.cluster.local:3003

# For Ingress/Custom Domain:
# USER_SERVICE_URL=https://api.yourdomain.com
# DASHBOARD_SERVICE_URL=https://api.yourdomain.com
# SETTINGS_SERVICE_URL=https://api.yourdomain.com

# ==========================================
# ENVIRONMENT
# ==========================================
NODE_ENV=development
PORT=8080
DEPLOYMENT_ENV=docker
