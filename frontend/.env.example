# Frontend Configuration - Platform-Agnostic Service Discovery

# ========================================
# 1. LOCAL DEVELOPMENT (localhost)
# ========================================
# USER_SERVICE_URL=http://localhost:3001
# DASHBOARD_SERVICE_URL=http://localhost:3002
# SETTINGS_SERVICE_URL=http://localhost:3003
# DEPLOYMENT_ENV=local

# ========================================
# 2. DOCKER COMPOSE
# ========================================
# USER_SERVICE_URL=http://user-service:3001
# DASHBOARD_SERVICE_URL=http://dashboard-service:3002
# SETTINGS_SERVICE_URL=http://settings-service:3003
# DEPLOYMENT_ENV=docker

# ========================================
# 3. KUBERNETES (ClusterIP Services)
# ========================================
# USER_SERVICE_URL=http://user-service.default.svc.cluster.local:3001
# DASHBOARD_SERVICE_URL=http://dashboard-service.default.svc.cluster.local:3002
# SETTINGS_SERVICE_URL=http://settings-service.default.svc.cluster.local:3003
# DEPLOYMENT_ENV=kubernetes

# ========================================
# 4. KUBERNETES (In same namespace)
# ========================================
# USER_SERVICE_URL=http://user-service:3001
# DASHBOARD_SERVICE_URL=http://dashboard-service:3002
# SETTINGS_SERVICE_URL=http://settings-service:3003
# DEPLOYMENT_ENV=kubernetes

# ========================================
# 5. KUBERNETES INGRESS (Single domain)
# ========================================
# USER_SERVICE_URL=http://api.example.com
# DASHBOARD_SERVICE_URL=http://api.example.com
# SETTINGS_SERVICE_URL=http://api.example.com
# DEPLOYMENT_ENV=kubernetes-ingress

# ========================================
# 6. AWS / CLOUD
# ========================================
# USER_SERVICE_URL=http://user-service-alb.example.com
# DASHBOARD_SERVICE_URL=http://dashboard-service-alb.example.com
# SETTINGS_SERVICE_URL=http://settings-service-alb.example.com
# DEPLOYMENT_ENV=aws

# ========================================
# 7. CUSTOM / ANY URL
# ========================================
# USER_SERVICE_URL=https://user-service.yourdomain.com
# DASHBOARD_SERVICE_URL=https://dashboard-service.yourdomain.com
# SETTINGS_SERVICE_URL=https://settings-service.yourdomain.com
# DEPLOYMENT_ENV=production

# ========================================
# Frontend Port (Optional)
# ========================================
# PORT=8080
